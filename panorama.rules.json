{
  "version": "1",
  "rules": [
    {
      "id": "exp-hospitality-subhead",
      "name": "Homepage hero subhead — hospitality campaign traffic",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "currentPath",
            "match": {
              "op": "equals",
              "value": "/"
            }
          },
          {
            "type": "utm",
            "param": "campaign",
            "match": {
              "op": "equals",
              "value": "hospitality"
            }
          }
        ]
      },
      "actions": [
        {
          "type": "textReplace",
          "selector": "[data-pano=\"hero-subhead\"]",
          "replace": "Furniture, joinery, doors and FF&E from our own workshops — one contract, one team, one pre-opening date."
        }
      ],
      "metric": "start_project_click",
      "segment": "utm_campaign=hospitality"
    },
    {
      "id": "exp-instagram-subhead",
      "name": "Homepage hero subhead — Instagram traffic",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "currentPath",
            "match": {
              "op": "equals",
              "value": "/"
            }
          },
          {
            "type": "utm",
            "param": "source",
            "match": {
              "op": "equals",
              "value": "instagram"
            }
          }
        ]
      },
      "actions": [
        {
          "type": "textReplace",
          "selector": "[data-pano=\"hero-subhead\"]",
          "replace": "Hospitality, commercial and residential interiors — designed, made in our own workshops, and delivered turnkey."
        }
      ],
      "metric": "start_project_click",
      "segment": "utm_source=instagram"
    },
    {
      "id": "exp-linkedin-headline",
      "name": "Homepage hero headline — LinkedIn traffic",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "currentPath",
            "match": {
              "op": "equals",
              "value": "/"
            }
          },
          {
            "type": "utm",
            "param": "source",
            "match": {
              "op": "equals",
              "value": "linkedin"
            }
          }
        ]
      },
      "actions": [
        {
          "type": "textReplace",
          "selector": "[data-pano=\"hero-headline\"]",
          "replace": "Three workshops. One team. Every hotel interior made and delivered — not outsourced."
        }
      ],
      "metric": "start_project_click",
      "segment": "utm_source=linkedin"
    },
    {
      "id": "exp-uae-headline",
      "name": "Homepage hero headline — UAE visitors",
      "description": "Needs geo from edge headers (initialContext.geo.country). Inert until geo is injected.",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "currentPath",
            "match": {
              "op": "equals",
              "value": "/"
            }
          },
          {
            "type": "geo",
            "field": "country",
            "match": {
              "op": "equals",
              "value": "AE"
            }
          }
        ]
      },
      "actions": [
        {
          "type": "textReplace",
          "selector": "[data-pano=\"hero-headline\"]",
          "replace": "Hospitality interiors made in İstanbul, delivered across the Gulf."
        }
      ],
      "consentRequired": true,
      "metric": "start_project_click",
      "segment": "geo:country=AE"
    },
    {
      "id": "exp-returning-cta",
      "name": "Homepage CTA headline — returning visitors",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "currentPath",
            "match": {
              "op": "equals",
              "value": "/"
            }
          },
          {
            "type": "session",
            "field": "isReturning",
            "match": {
              "op": "equals",
              "value": true
            }
          }
        ]
      },
      "actions": [
        {
          "type": "textReplace",
          "selector": "[data-pano=\"cta-headline\"]",
          "replace": "Tell us what you're building — we'll send a project approach within 48 hours."
        }
      ],
      "metric": "start_project_click",
      "segment": "session:returning"
    },
    {
      "id": "homepage-dual-cta-returning-organic-visitors-secondary-evidence-path-button",
      "name": "Homepage dual CTA — returning organic visitors (secondary evidence-path button)",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "currentPath",
            "match": {
              "op": "equals",
              "value": "/"
            }
          },
          {
            "type": "session",
            "field": "isReturning",
            "match": {
              "op": "equals",
              "value": true
            }
          }
        ]
      },
      "actions": [
        {
          "type": "modifyButton",
          "selector": "[data-pano='cta-button']",
          "changes": {
            "addSecondary": true,
            "secondaryText": "View delivered projects",
            "secondaryHref": "/projects",
            "secondaryStyle": "outline",
            "secondaryClass": "border border-[#732017] text-[#732017] hover:bg-[#732017] hover:text-white"
          }
        }
      ],
      "metric": "click_to_projects_or_contact",
      "holdout": 0.12
    },
    {
      "id": "homepage-qualification-strip-linkedin-returning-visitors-inject-after-group-section",
      "name": "Homepage qualification strip — LinkedIn returning visitors (inject after Group section)",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "utm",
            "param": "source",
            "match": {
              "op": "equals",
              "value": "linkedin"
            }
          },
          {
            "type": "session",
            "field": "isReturning",
            "match": {
              "op": "equals",
              "value": true
            }
          }
        ]
      },
      "actions": [
        {
          "type": "injectField",
          "after": "[data-section='group']",
          "content": {
            "eyebrow": "Qualifications",
            "items": [
              {
                "label": "Fire-rated door systems",
                "detail": "Tested and certified to BS 476 / EN 1634"
              },
              {
                "label": "Acoustic performance",
                "detail": "Tested to BS EN ISO 10140"
              },
              {
                "label": "Quality management",
                "detail": "ISO 9001 certified manufacturing"
              }
            ],
            "cta": {
              "text": "Request capability statement",
              "href": "/contact"
            }
          },
          "style": {
            "borderTop": "1px solid #e5e4e0",
            "py": "3rem",
            "bg": "#f4f3ef",
            "font": "Archivo",
            "color": "#18120f"
          }
        }
      ],
      "metric": "click_to_contact",
      "holdout": 0.12
    },
    {
      "id": "homepage-siladu-materials-strip-design-channel-visitors-inject-after-manufacturing",
      "name": "Homepage SILADU materials strip — design-channel visitors (inject after manufacturing)",
      "status": "active",
      "audience": {
        "type": "any",
        "conditions": [
          {
            "type": "referrer",
            "match": {
              "op": "contains",
              "value": "pinterest"
            }
          },
          {
            "type": "referrer",
            "match": {
              "op": "contains",
              "value": "behance"
            }
          },
          {
            "type": "utm",
            "param": "source",
            "match": {
              "op": "contains",
              "value": "design"
            }
          }
        ]
      },
      "actions": [
        {
          "type": "injectField",
          "after": "[data-section='manufacturing']",
          "content": {
            "eyebrow": "Materials & Surfaces",
            "headline": "SILADU",
            "body": "Veneer, finish and surface development — the palette behind every ORWOOD interior.",
            "cta": {
              "text": "Inside the workshops",
              "href": "/manufacturing"
            }
          },
          "style": {
            "borderTop": "1px solid #e5e4e0",
            "py": "4rem",
            "bg": "#f4f3ef",
            "font": "Archivo",
            "color": "#18120f"
          }
        }
      ],
      "metric": "click_to_manufacturing",
      "holdout": 0.15
    },
    {
      "id": "homepage-residential-proof-overlay-desktop-new-visitors-exit-intent",
      "name": "Homepage residential proof overlay — desktop new visitors (exit intent)",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "device",
            "field": "type",
            "match": {
              "op": "equals",
              "value": "desktop"
            }
          },
          {
            "type": "session",
            "field": "isNew",
            "match": {
              "op": "equals",
              "value": true
            }
          },
          {
            "type": "exitIntent"
          }
        ]
      },
      "actions": [
        {
          "type": "overlay",
          "position": "bottom-right",
          "content": {
            "headline": "Private & residential interiors",
            "body": "Bespoke joinery, kitchens, wardrobes and libraries — finished like furniture, not fitted like cabinetry.",
            "cta": {
              "text": "View residential projects",
              "href": "/industries/residential"
            },
            "dismiss": true
          },
          "style": {
            "maxWidth": "420px",
            "bg": "#f4f3ef",
            "border": "1px solid #e5e4e0",
            "font": "Archivo",
            "color": "#18120f"
          }
        }
      ],
      "metric": "click_to_residential",
      "holdout": 0.15,
      "priority": 1
    },
    {
      "id": "exp-exit-intent-projects",
      "name": "Exit-intent projects overlay — new visitors",
      "description": "Non-intrusive corner overlay at exit intent directing new visitors to the projects page (proof asset). Yields to higher-priority residential overlay on desktop.",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "currentPath",
            "match": {
              "op": "equals",
              "value": "/"
            }
          },
          {
            "type": "session",
            "field": "isNew",
            "match": {
              "op": "equals",
              "value": true
            }
          },
          {
            "type": "exitIntent"
          }
        ]
      },
      "actions": [
        {
          "type": "overlay",
          "position": "bottom-right",
          "animation": "slide",
          "autoCloseMs": 8000,
          "content": {
            "headline": "Before you go — see what we've delivered.",
            "cta": {
              "text": "View projects →",
              "href": "/projects"
            },
            "dismiss": true
          },
          "style": {
            "maxWidth": "360px",
            "bg": "#f4f3ef",
            "border": "1px solid #e5e4e0",
            "font": "Archivo",
            "color": "#18120f"
          }
        }
      ],
      "metric": "projects_click",
      "holdout": 0.1,
      "frequencyCap": {
        "per": "session",
        "max": 1
      },
      "priority": 0
    },
    {
      "id": "exp-deep-scroll-sticky-cta",
      "name": "Homepage sticky CTA — desktop deep-scroll engaged visitors",
      "description": "Overlay banner at bottom triggered by 70% scroll depth + 30s time on page. Surfaces the conversion action mid-journey for engaged desktop visitors who may never reach the final CTA section.",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "currentPath",
            "match": {
              "op": "equals",
              "value": "/"
            }
          },
          {
            "type": "device",
            "field": "type",
            "match": {
              "op": "equals",
              "value": "desktop"
            }
          },
          {
            "type": "scrollDepth",
            "percent": 70
          },
          {
            "type": "timeOnPage",
            "seconds": 30
          }
        ]
      },
      "actions": [
        {
          "type": "overlay",
          "overlay": "banner",
          "position": "bottom",
          "animation": "slide",
          "dismissible": true,
          "id": "pa-sticky-cta-desktop",
          "content": {
            "headline": "Ready to start a project?",
            "body": "Tell us what you’re building — we’ll send a project approach within 48 hours.",
            "cta": {
              "text": "Get in touch",
              "href": "/contact"
            },
            "dismiss": true
          },
          "style": {
            "bg": "#18120f",
            "color": "#f4f3ef",
            "font": "Archivo",
            "border": "none",
            "maxWidth": "100vw"
          }
        }
      ],
      "metric": "start_project_click",
      "holdout": 0.1,
      "frequencyCap": {
        "per": "session",
        "max": 1
      }
    },
    {
      "id": "exp-mobile-sticky-cta",
      "name": "Homepage sticky CTA — mobile scroll-engaged visitors",
      "description": "Overlay banner at bottom triggered by 50% scroll depth on mobile. Surfaces the conversion action earlier on mobile where the homepage is ~12 full scrolls.",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "currentPath",
            "match": {
              "op": "equals",
              "value": "/"
            }
          },
          {
            "type": "device",
            "field": "mobile",
            "match": {
              "op": "equals",
              "value": true
            }
          },
          {
            "type": "scrollDepth",
            "percent": 50
          }
        ]
      },
      "actions": [
        {
          "type": "overlay",
          "overlay": "banner",
          "position": "bottom",
          "animation": "slide",
          "dismissible": true,
          "id": "pa-sticky-cta-mobile",
          "content": {
            "headline": "Ready to start a project?",
            "cta": {
              "text": "Get in touch",
              "href": "/contact"
            },
            "dismiss": true
          },
          "style": {
            "bg": "#18120f",
            "color": "#f4f3ef",
            "font": "Archivo",
            "border": "none",
            "maxWidth": "100vw"
          }
        }
      ],
      "metric": "mobile_cta_click",
      "holdout": 0.1,
      "frequencyCap": {
        "per": "session",
        "max": 1
      }
    },
    {
      "id": "exp-hospitality-manufacturing-emphasis",
      "name": "Manufacturing section visual emphasis — hospitality campaign traffic",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "currentPath",
            "match": {
              "op": "equals",
              "value": "/"
            }
          },
          {
            "type": "utm",
            "param": "campaign",
            "match": {
              "op": "equals",
              "value": "hospitality"
            }
          }
        ]
      },
      "actions": [
        {
          "type": "setStyle",
          "selector": "[data-pano='manufacturing-section']",
          "styles": {
            "border-left": "4px solid #732017"
          }
        },
        {
          "type": "textReplace",
          "selector": "[data-pano='manufacturing-link']",
          "find": "Inside the workshops",
          "replace": "See our production facilities"
        }
      ],
      "metric": "manufacturing_click",
      "holdout": 0.1,
      "segment": "utm_campaign=hospitality"
    },
    {
      "id": "hospitality-campaign-hero-scale-proof",
      "name": "Hospitality-campaign hero scale proof",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "currentPath",
            "match": { "op": "equals", "value": "/projects" }
          },
          {
            "type": "utm",
            "param": "campaign",
            "match": { "op": "equals", "value": "hospitality", "caseInsensitive": true }
          }
        ]
      },
      "actions": [
        {
          "type": "textReplace",
          "find": "A selection across hospitality, commercial and residential. Each one designed, manufactured and delivered by the same house.",
          "replace": "360+ hotel keys delivered turnkey — designed, manufactured and handed over by one team."
        }
      ],
      "description": "Hospitality VP (weight 9) sees no scale signal in the hero — resonance 2/3. The intro is generic across all segments; hospitality campaign traffic paid to acquire deserves a scale-proof first impression.",
      "metric": "projects_hospitality_scroll_depth",
      "holdout": 0.1
    },
    {
      "id": "sticky-cta-on-deep-scroll",
      "name": "Sticky CTA on deep scroll",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "currentPath",
            "match": { "op": "equals", "value": "/projects" }
          },
          {
            "type": "scrollDepth",
            "percent": 60
          }
        ]
      },
      "actions": [
        {
          "type": "overlay",
          "overlay": "banner",
          "html": "<div style=\"display:flex;align-items:center;justify-content:space-between;padding:14px 24px;font-family:Archivo,sans-serif;font-size:14px;color:#18120f;background:#f4f3ef;border-top:1px solid #e5e2dc\"><span>Interested in what you see?</span><a href=\"/contact\" style=\"display:inline-block;padding:8px 20px;background:#732017;color:#f4f3ef;text-decoration:none;font-size:13px;font-weight:500;letter-spacing:0.03em\">Discuss a project like this</a></div>",
          "dismissible": true
        }
      ],
      "description": "Same pattern shipped on homepage (ins-635d77c3). /projects has 6 cards + filter bar before the only CTA — ~8 mobile scrolls. Engaged evaluators drop before reaching it.",
      "metric": "projects_sticky_cta_click",
      "holdout": 0.1
    },
    {
      "id": "returning-visitor-fast-path-banner",
      "name": "Returning-visitor fast-path banner",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "currentPath",
            "match": { "op": "equals", "value": "/projects" }
          },
          {
            "type": "session",
            "field": "isReturning",
            "match": { "op": "equals", "value": true }
          }
        ]
      },
      "actions": [
        {
          "type": "overlay",
          "overlay": "banner",
          "html": "<div style=\"display:flex;align-items:center;justify-content:center;gap:16px;padding:12px 24px;font-family:Archivo,sans-serif;font-size:13px;color:#18120f;background:#f4f3ef;border-bottom:1px solid #e5e2dc\"><span>Welcome back — ready to discuss your project?</span><a href=\"/contact\" style=\"padding:6px 16px;background:#732017;color:#f4f3ef;text-decoration:none;font-size:12px;font-weight:500;letter-spacing:0.03em\">Get in touch</a></div>",
          "dismissible": true
        }
      ],
      "description": "Returning visitors to the portfolio page are late-stage evaluators. Homepage returning-visitor banner shipped (ins-dc8fba78). /projects needs the same pattern — these visitors came back to compare or gather evidence, not to re-browse.",
      "metric": "returning_projects_cta_click",
      "holdout": 0.1
    },
    {
      "id": "exit-intent-enquiry-recovery",
      "name": "Exit-intent enquiry recovery",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "currentPath",
            "match": { "op": "equals", "value": "/projects" }
          },
          {
            "type": "exitIntent"
          }
        ]
      },
      "actions": [
        {
          "type": "overlay",
          "overlay": "popup",
          "html": "<div style=\"max-width:340px;padding:28px 24px;font-family:Archivo,sans-serif;background:#f4f3ef;border:1px solid #e5e2dc\"><p style=\"margin:0 0 16px;font-size:15px;font-weight:500;color:#18120f\">Interested in a similar scope?</p><p style=\"margin:0 0 20px;font-size:13px;color:#57534e;line-height:1.5\">Tell us about your project — we'll show you how we'd approach it.</p><a href=\"/contact\" style=\"display:inline-block;padding:10px 22px;background:#732017;color:#f4f3ef;text-decoration:none;font-size:13px;font-weight:500;letter-spacing:0.03em\">Start a conversation</a></div>",
          "dismissible": true
        }
      ],
      "description": "Homepage exit-intent overlay shipped (ins-d8366862) and recovered bouncing visitors to /projects. Now /projects itself needs a recovery mechanism — but pointing to /contact (the conversion), not back to /projects.",
      "metric": "projects_exit_cta_click",
      "holdout": 0.1
    },
    {
      "id": "gcc-localised-cta-button",
      "name": "GCC-localised CTA button",
      "status": "active",
      "audience": {
        "type": "all",
        "conditions": [
          {
            "type": "currentPath",
            "match": { "op": "equals", "value": "/projects" }
          },
          {
            "type": "geo",
            "field": "country",
            "match": { "op": "in", "value": ["AE", "QA", "SA"], "caseInsensitive": true }
          }
        ]
      },
      "actions": [
        {
          "type": "modifyButton",
          "selector": "section:last-of-type a[href='/contact']",
          "label": "Discuss your project with our Dubai team"
        }
      ],
      "description": "GCC is the #1 target geography. Delivered projects in Doha, Dubai, Riyadh prove capability but the CTA carries no regional signal. GCC principals need confidence in local presence before enquiring.",
      "metric": "gcc_projects_cta_click",
      "holdout": 0.1,
      "consentRequired": true
    }
  ]
}
