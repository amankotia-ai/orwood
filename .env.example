# ── Email (Resend) ──────────────────────────────────────────
# Required to activate the post-enquiry nurture sequence.
# Get your key at https://resend.com/api-keys
RESEND_API_KEY=

# "From" address for nurture emails (must be a verified domain in Resend).
# Default: ORWOOD <hello@orwood.com>
EMAIL_FROM=

# ── Site ────────────────────────────────────────────────────
# Base URL used in email template links.
# Default: https://orwood.com
NEXT_PUBLIC_BASE_URL=

# WhatsApp Business number (digits only, with country code).
# Default: placeholder from lib/content.ts
WHATSAPP_NUMBER=

# ── Email queue (Vercel KV / Upstash Redis) ────────────────
# Required in production for scheduled drip emails.
# Without these, drip emails log to console but don't persist.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# ── Cron protection ────────────────────────────────────────
# Secret used to authorize /api/cron/* endpoints.
# Vercel sets this automatically when you configure crons.
CRON_SECRET=
